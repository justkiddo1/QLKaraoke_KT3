<Window x:Class="DoQuangHuy_2001215807_KT2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:DoQuangHuy_2001215807_KT2.ViewModels"
        Title="MainWindow" Height="520" Width="740"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:PhongViewModel/>
    </Window.DataContext>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== FORM NHẬP LIỆU ===== -->
        <GroupBox Header="Thông tin phòng" Grid.Row="0" Padding="10" Margin="0,0,0,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="34"/>
                    <RowDefinition Height="34"/>
                    <RowDefinition Height="70"/>
                    <RowDefinition Height="34"/>
                    <RowDefinition Height="40"/>
                </Grid.RowDefinitions>

                <!-- Chọn tầng + Mã phòng -->
                <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center">
                    <Label Content="Chọn tầng nhà:" Width="110" VerticalAlignment="Center"/>
                    <ComboBox ItemsSource="{Binding DanhSachTang}"
                              SelectedItem="{Binding SelectedTang}"
                              DisplayMemberPath="TenNhom"
                              Width="140" Height="26"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center">
                    <Label Content="Mã phòng:" Width="80" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding MaPhong, UpdateSourceTrigger=PropertyChanged}"
                             Width="160" Height="26"/>
                </StackPanel>

                <!-- Tên phòng -->
                <StackPanel Orientation="Horizontal" Grid.Row="1" Grid.Column="0"
                            Grid.ColumnSpan="2" VerticalAlignment="Center">
                    <Label Content="Tên phòng:" Width="110" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding TenPhong, UpdateSourceTrigger=PropertyChanged}"
                             Width="350" Height="26"/>
                </StackPanel>

                <!-- Giá phòng + Loại phòng -->
                <StackPanel Orientation="Horizontal" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center">
                    <Label Content="Giá phòng:" Width="110" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding GiaPhong, UpdateSourceTrigger=PropertyChanged}"
                             Width="160" Height="26"/>
                </StackPanel>

                <GroupBox Header="Loại phòng" Grid.Row="2" Grid.Column="1" Padding="8,2">
                    <StackPanel Margin="0,4">
                        <RadioButton Content="Phòng quạt"     IsChecked="{Binding IsQuat}"    Margin="0,3"/>
                        <RadioButton Content="Phòng máy lạnh" IsChecked="{Binding IsMayLanh}" Margin="0,3"/>
                    </StackPanel>
                </GroupBox>

                <!-- Sức chứa -->
                <StackPanel Orientation="Horizontal" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center">
                    <Label Content="Sức chứa tối đa:" Width="110" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding SucChua, UpdateSourceTrigger=PropertyChanged}"
                             Width="160" Height="26"/>
                </StackPanel>

                <!-- CRUD Buttons -->
                <StackPanel Orientation="Horizontal" Grid.Row="4" Grid.Column="0"
                            Grid.ColumnSpan="2" HorizontalAlignment="Center">
                    <Button Content="Thêm"  Command="{Binding AddCommand}"   Width="80" Height="28" Margin="5,0"/>
                    <Button Content="Xóa"   Command="{Binding ClearCommand}" Width="80" Height="28" Margin="5,0"/>
                    <Button Content="Sửa"   Command="{Binding EditCommand}"  Width="80" Height="28" Margin="5,0"/>
                    <Button Content="Lưu"   Command="{Binding SaveCommand}"  Width="80" Height="28" Margin="5,0"/>
                    <Button Content="Tìm kiếm" Click="BtnTimKiem_Click"
                            Width="90" Height="28" Margin="20,0,5,0"
                            Background="#1976D2" Foreground="White" FontWeight="Bold"/>
                    <Button Content="Đặt phòng" Click="BtnDatPhong_Click"
                            Width="90" Height="28" Margin="5,0"
                            Background="#388E3C" Foreground="White" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- ===== DATAGRID ===== -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding DanhSachPhong}"
                  SelectedItem="{Binding SelectedPhong}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  SelectionMode="Single"
                  GridLinesVisibility="All"
                  AlternatingRowBackground="#F0F4FF">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã phòng"    Binding="{Binding MaPhong}"                        Width="80"/>
                <DataGridTextColumn Header="Tên phòng"   Binding="{Binding TenPhong}"                       Width="140"/>
                <DataGridTextColumn Header="Sức chứa"    Binding="{Binding SucChua}"                        Width="75"/>
                <DataGridTextColumn Header="Giá phòng"   Binding="{Binding GiaPhong, StringFormat=N0}"      Width="100"/>
                <DataGridTextColumn Header="Tên tầng"    Binding="{Binding LOAIPHONG.TenNhom}"              Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
